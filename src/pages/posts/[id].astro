---
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---
<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{post.data.title} — Manuel Moscariello</title>
  <meta name="description" content={post.data.excerpt} />
  <link rel="icon" type="image/png" href="/img/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=DM+Mono:wght@300;400&family=DM+Sans:wght@300;400&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0e0e0d; --bg2: #151513; --surface: #1c1c1a; --border: #2a2a27;
      --text: #e8e4dc; --muted: #7a7870;
      --green: #7fb87e; --green2: #5a8a5e;
      --gold: #a8864e;
      --fd: 'Playfair Display', Georgia, serif;
      --fm: 'DM Mono', monospace;
      --fb: 'DM Sans', sans-serif;
    }
    body { background: var(--bg); color: var(--text); font-family: var(--fb); font-weight: 300; line-height: 1.6; }

    nav { display: flex; justify-content: space-between; align-items: center; padding: 1.2rem 2rem; border-bottom: 1px solid var(--border); background: var(--bg); position: sticky; top: 0; z-index: 100; }
    .nav-logo { font-family: var(--fm); font-size: 0.7rem; letter-spacing: 0.2em; color: var(--green); text-decoration: none; text-transform: uppercase; }
    .nav-back { font-family: var(--fm); font-size: 0.65rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.3s; }
    .nav-back:hover { color: var(--green); }

    .hero { position: relative; height: 50vh; min-height: 300px; overflow: hidden; background: var(--bg2); }
    .hero img { width: 100%; height: 100%; object-fit: cover; opacity: 0.7; }
    .hero-overlay { position: absolute; inset: 0; background: linear-gradient(to bottom, transparent 30%, var(--bg) 100%); }
    .hero-placeholder { width: 100%; height: 100%; background: linear-gradient(135deg, #0d150d 0%, #0e0e0d 60%, #111a0e 100%); }

    .post-header { max-width: 720px; margin: 0 auto; padding: 3rem 2rem 2rem; }
    .post-tags { display: flex; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
    .post-tag { font-family: var(--fm); font-size: 0.55rem; letter-spacing: 0.12em; text-transform: uppercase; padding: 0.2rem 0.6rem; border: 1px solid var(--green2); color: var(--green); }
    .post-title { font-family: var(--fd); font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 900; line-height: 1.05; letter-spacing: -0.02em; margin-bottom: 1rem; }
    .post-meta { font-family: var(--fm); font-size: 0.65rem; color: var(--muted); letter-spacing: 0.1em; }

    .post-body { max-width: 720px; margin: 0 auto; padding: 2rem; }
    .post-body p { color: var(--muted); font-size: 1rem; line-height: 1.9; margin-bottom: 1.5rem; }
    .post-body p strong { color: var(--text); font-weight: 400; }
    .post-body h2 { font-family: var(--fd); font-size: 1.6rem; font-weight: 700; color: var(--green); margin: 2.5rem 0 1rem; }
    .post-body h3 { font-family: var(--fd); font-size: 1.2rem; font-weight: 700; color: var(--text); margin: 2rem 0 0.8rem; }
    .post-body img { width: 100%; height: auto; margin: 2rem 0; border: 1px solid var(--border); }
    .post-body iframe { width: 100%; margin: 2rem 0; border: none; }
    .post-body a { color: var(--green); text-decoration: none; border-bottom: 1px solid var(--green2); transition: color 0.3s; }
    .post-body a:hover { color: var(--text); }
    .post-body blockquote { border-left: 2px solid var(--green2); padding-left: 1.5rem; margin: 2rem 0; color: var(--muted); font-style: italic; }
    .post-body code { font-family: var(--fm); font-size: 0.85rem; background: var(--surface); padding: 0.2rem 0.4rem; color: var(--green); }
    .post-body ul, .post-body ol { color: var(--muted); padding-left: 1.5rem; margin-bottom: 1.5rem; }
    .post-body li { margin-bottom: 0.5rem; line-height: 1.8; }

    .post-footer { max-width: 720px; margin: 0 auto; padding: 2rem; border-top: 1px solid var(--border); }
    .back-link { font-family: var(--fm); font-size: 0.65rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); text-decoration: none; transition: color 0.3s; }
    .back-link:hover { color: var(--green); }

    footer { border-top: 1px solid var(--border); padding: 2rem; display: flex; justify-content: space-between; margin-top: 4rem; }
    footer p { font-family: var(--fm); font-size: 0.6rem; color: var(--muted); }
    footer a { font-family: var(--fm); font-size: 0.6rem; color: var(--gold); text-decoration: none; }

    @media (max-width: 768px) {
      nav { padding: 1rem 1.5rem; }
      .post-header, .post-body, .post-footer { padding: 1.5rem; }
      .hero { height: 35vh; }
    }
  </style>
</head>
<body>

  <nav>
    <a href="/" class="nav-logo">arteteco</a>
    <a href="/" class="nav-back">← tutti i post</a>
  </nav>

  <div class="hero">
    {post.data.cover
      ? <img src={post.data.cover} alt={post.data.title} />
      : <div class="hero-placeholder"></div>
    }
    <div class="hero-overlay"></div>
  </div>

  <header class="post-header">
    <div class="post-tags">
      {post.data.tags.map(tag => (
        <span class="post-tag">{tag}</span>
      ))}
    </div>
    <h1 class="post-title">{post.data.title}</h1>
    <p class="post-meta">
      {new Date(post.data.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })}
    </p>
  </header>

  <article class="post-body">
    <Content />
  </article>

  <div class="post-footer">
    <a href="/" class="back-link">← torna alla home</a>
  </div>

  <footer>
    <p>© Manuel Moscariello</p>
    <a href="/">arteteco.com</a>
  </footer>

</body>
</html>
